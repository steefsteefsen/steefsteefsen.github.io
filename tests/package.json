{
  "name": "stefan-site-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":90,\"functions\":90,\"branches\":90,\"statements\":90}}' 2>&1 | tee ../logs/test-run.log",
    "test:ci": "jest --coverage --ci --coverageThreshold='{\"global\":{\"lines\":90,\"functions\":90,\"branches\":90,\"statements\":90}}'"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageDirectory": "../logs/coverage",
    "collectCoverageFrom": [
      "../*.js",
      "!../node_modules/**"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  }
}
